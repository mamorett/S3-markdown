# S3-compatible endpoint URL (leave empty for native AWS S3)
S3_ENDPOINT_URL=https://<namespace>.compat.objectstorage.<region>.oraclecloud.com

# AWS-style credentials (used by all S3-compatible providers)
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key

# The bucket to read Markdown files from
S3_BUCKET_NAME=your-bucket-name

# AWS region (required by boto3 even for non-AWS providers; use any valid string)
S3_REGION_NAME=us-east-1
